{
  "expo": {
    "name": "hotelapp",
    "slug": "hotelapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hotelapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFBC0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hotelapp.restaurant"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFBC0D"
      },
      "package": "com.hotelapp.restaurant"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
